# terraform/terraform.tfvars.example
#
# Copy to terraform.tfvars (gitignored) and fill in real values.
# None of these are secrets - just environment-specific identifiers.

aws_region            = "ca-central-1"
environment            = "production"
artifact_bucket_name  = "your-org-secure-python-app-artifacts"
trusted_ingress_cidr  = "203.0.113.0/24" # replace with your VPN/ALB CIDR - never 0.0.0.0/0
github_org             = "your-github-org"
github_repo            = "secure-python-app-pipeline"
instance_type           = "t3.micro"
alarm_notification_email = "security-team@example.com"
